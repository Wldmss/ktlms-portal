    <!-- Creates the Spring Container shared by all Servlets and Filters -->
    <listener>
        <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
    </listener>

    <!-- .do redirect filter -->
    <filter>
        <filter-name>urlSuffixRedirectFilter</filter-name>
        <filter-class>com.kt.ktedu.common.filter.UrlSuffixRedirectFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>urlSuffixRedirectFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- form xss filter -->
    <filter>
        <filter-name>formXssFilter</filter-name>
        <filter-class>com.kt.ktedu.common.security.FormXssFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>formXssFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- url encoding filter -->
    <filter>
        <filter-name>resourceUrlEncodingFilter</filter-name>
        <filter-class>org.springframework.web.servlet.resource.ResourceUrlEncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>resourceUrlEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- UTF-8 Encoding Filter for Spring -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>forceEncoding</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

